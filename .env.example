# Payment Tracking System — Environment Variables
# Copy this file to .env and fill in your values

# ── Google Sheets ──────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# ── WAHA (WhatsApp HTTP API) ───────────────────────────────────────────────────
WAHA_API_KEY=your_waha_api_key_here
WAHA_BOT_NUMBER=905XXXXXXXXX@c.us
AUTHORIZED_NUMBER=49XXXXXXXXXX@c.us

# ── Gemini AI ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Gmail SMTP ─────────────────────────────────────────────────────────────────
GMAIL_FROM=your_gmail@gmail.com
GMAIL_TO=recipient@example.com

# ── n8n ────────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=your_random_32char_string_here

# ── WAHA Dashboard ─────────────────────────────────────────────────────────────
WAHA_DASHBOARD_USER=admin
WAHA_DASHBOARD_PASS=your_dashboard_password_here
WAHA_WEBHOOK_URL=http://n8n:5678/webhook/YOUR_WEBHOOK_UUID

# ── Report API ─────────────────────────────────────────────────────────────────
COMPANY_NAME=Your Company Name
REPORT_API_PORT=5050
